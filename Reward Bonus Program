<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pakistan Bonus Rewards Program – Check Your Status</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ===========================
   CSS VARIABLES & RESET
=========================== */
:root {
  --green-dark:   #0a4a2e;
  --green-mid:    #0f6b42;
  --green-light:  #1a9158;
  --green-bright: #22c55e;
  --gold:         #f5c842;
  --gold-light:   #fde68a;
  --gold-dark:    #d4a017;
  --white:        #ffffff;
  --off-white:    #f8fdf9;
  --gray-soft:    #e8f5ec;
  --text-dark:    #0c2a1a;
  --text-mid:     #2d5a3d;
  --shadow-card:  0 8px 32px rgba(10,74,46,0.13);
  --shadow-glow:  0 0 24px rgba(34,197,94,0.18);
  --radius-lg:    20px;
  --radius-xl:    28px;
  --transition:   all 0.3s cubic-bezier(.4,0,.2,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;font-size:16px;}
body{
  font-family:'Nunito',sans-serif;
  background:var(--off-white);
  color:var(--text-dark);
  overflow-x:hidden;
  line-height:1.6;
}
img{max-width:100%;display:block;}
a{text-decoration:none;color:inherit;}
button,input,select{font-family:inherit;}

/* ===========================
   UTILITY
=========================== */
.container{width:100%;max-width:1160px;margin:0 auto;padding:0 20px;}
.flex{display:flex;}
.flex-center{display:flex;align-items:center;justify-content:center;}
.grid-3{
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:24px;
}
/* Remove the lone-card centering rules */

.text-center{text-align:center;}
.section{padding:72px 0;}

/* ===========================
   FADE-IN ANIMATION
=========================== */
.fade-up{
  opacity:0;
  transform:translateY(36px);
  transition:opacity 0.7s ease, transform 0.7s ease;
}
.fade-up.visible{opacity:1;transform:translateY(0);}

/* ===========================
   TOP BADGES BAR
=========================== */
#top-bar{
  background:linear-gradient(90deg,var(--green-dark) 0%,var(--green-mid) 60%,var(--green-dark) 100%);
  padding:12px 0;
}
.top-bar-inner{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:12px;
  text-align:center;
}
.top-bar-row1{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:14px;
  flex-wrap:wrap;
}
.top-bar-row2{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;
}
.badge{
  display:inline-flex;
  align-items:center;
  gap:8px;
  background:rgba(255,255,255,0.09);
  border:1px solid rgba(245,200,66,0.35);
  border-radius:40px;
  padding:6px 16px;
  font-size:0.82rem;
  font-weight:700;
  color:var(--gold-light);
  letter-spacing:0.02em;
  white-space:nowrap;
}
.badge svg{flex-shrink:0;}
.badge-center{
  background:linear-gradient(135deg,var(--gold-dark),var(--gold));
  color:var(--green-dark);
  border-color:transparent;
  box-shadow:0 2px 14px rgba(245,200,66,0.4);
  animation:pulse-badge 2s infinite;
}
@keyframes pulse-badge{0%,100%{box-shadow:0 2px 14px rgba(245,200,66,0.4);}50%{box-shadow:0 2px 28px rgba(245,200,66,0.75);}}
.timer-wrap{display:flex;align-items:center;gap:10px;}
.timer-label{font-size:0.82rem;color:var(--gold-light);font-weight:700;letter-spacing:0.04em;}
#countdown{
  display:flex;gap:5px;
}
.time-block{
  background:rgba(255,255,255,0.12);
  border:1px solid rgba(245,200,66,0.3);
  border-radius:8px;
  padding:4px 8px;
  min-width:36px;
  text-align:center;
  font-weight:800;
  font-size:1.05rem;
  color:var(--white);
  letter-spacing:0.04em;
}
.time-sep{color:var(--gold);font-weight:800;font-size:1.1rem;line-height:1.8;}

/* ===========================
   HERO SECTION
=========================== */
#hero{
  position:relative;
  background:linear-gradient(160deg,#07391f 0%,#0f6b42 45%,#0d5535 100%);
  overflow:hidden;
  padding:44px 0 52px;
  text-align:center;
}
#hero::before{
  content:'';
  position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 0%,rgba(245,200,66,0.12) 0%,transparent 65%);
  pointer-events:none;
}
/* Decorative crescent + star */
.hero-decor{
  position:absolute;top:18px;right:48px;
  opacity:0.12;
  pointer-events:none;
}
.hero-tag{
  display:inline-flex;
  align-items:center;
  gap:8px;
  background:rgba(245,200,66,0.15);
  border:1px solid rgba(245,200,66,0.45);
  border-radius:40px;
  padding:7px 20px;
  font-size:0.82rem;
  font-weight:700;
  color:var(--gold-light);
  margin-bottom:14px;
  letter-spacing:0.04em;
}
#hero h1{
  font-family:'Playfair Display',serif;
  font-size:clamp(2rem,5vw,3.4rem);
  font-weight:800;
  color:var(--white);
  line-height:1.18;
  margin-bottom:22px;
  text-shadow:0 2px 24px rgba(0,0,0,0.25);
}
#hero h1 span{color:var(--gold);}
.hero-sub{
  font-size:clamp(1rem,2.5vw,1.2rem);
  color:rgba(255,255,255,0.87);
  max-width:560px;
  margin:0 auto 36px;
  font-weight:600;
}
.btn-primary{
  display:inline-flex;
  align-items:center;
  gap:10px;
  background:linear-gradient(135deg,#22c55e,#16a34a);
  color:var(--white);
  font-size:1.15rem;
  font-weight:800;
  padding:18px 48px;
  border-radius:50px;
  border:none;
  cursor:pointer;
  box-shadow:0 6px 32px rgba(34,197,94,0.45);
  transition:var(--transition);
  letter-spacing:0.02em;
  position:relative;
  overflow:hidden;
}
.btn-primary::after{
  content:'';
  position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.18),transparent);
  border-radius:inherit;
}
.btn-primary:hover{
  transform:translateY(-3px) scale(1.04);
  box-shadow:0 12px 44px rgba(34,197,94,0.6);
}
.btn-primary:active{transform:translateY(0) scale(0.98);}
.hero-free{
  margin-top:14px;
  font-size:0.88rem;
  color:rgba(255,255,255,0.65);
  display:flex;align-items:center;justify-content:center;gap:6px;
}
.hero-free svg{color:var(--gold);}

/* Confetti canvas */
#confetti-canvas{
  position:absolute;inset:0;
  pointer-events:none;
  z-index:0;
}
.hero-content{position:relative;z-index:1;}

/* ===========================
   REWARD CARDS
=========================== */
#rewards{background:var(--white);padding:80px 0;}
#rewards .container,#testimonials .container,#live .container{text-align:center;}
#rewards .grid-3,#testimonials .grid-3,.live-grid{text-align:left;}
.section-label{
  font-size:0.82rem;
  font-weight:700;
  letter-spacing:0.12em;
  text-transform:uppercase;
  color:var(--green-light);
  margin-bottom:10px;
}
.section-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(1.6rem,3.5vw,2.5rem);
  font-weight:800;
  color:var(--green-dark);
  margin-bottom:14px;
}
.section-sub{
  font-size:1rem;
  color:var(--text-mid);
  max-width:500px;
  margin:0 auto 52px;
}
.reward-card{
  background:var(--white);
  border-radius:var(--radius-xl);
  border:1.5px solid rgba(34,197,94,0.15);
  box-shadow:var(--shadow-card);
  padding:36px 28px 30px;
  text-align:center;
  position:relative;
  overflow:hidden;
  transition:var(--transition);
  cursor:default;
}
.reward-card::before{
  content:'';
  position:absolute;top:0;left:0;right:0;height:4px;
  background:linear-gradient(90deg,var(--gold-dark),var(--gold));
}
.reward-card:hover{
  transform:translateY(-8px);
  box-shadow:0 20px 52px rgba(10,74,46,0.18), var(--shadow-glow);
  border-color:rgba(34,197,94,0.4);
}
.reward-card.featured{
  border-color:var(--gold);
  background:linear-gradient(160deg,#fff9e6 0%,#ffffff 100%);
}
.reward-card.featured::before{
  background:linear-gradient(90deg,var(--gold),#f5c842,var(--gold-dark));
  height:5px;
}
.card-badge{
  position:absolute;top:18px;right:18px;
  background:linear-gradient(135deg,var(--gold-dark),var(--gold));
  color:var(--green-dark);
  font-size:0.7rem;
  font-weight:800;
  padding:4px 12px;
  border-radius:20px;
  letter-spacing:0.06em;
  text-transform:uppercase;
}
.reward-icon{
  width:80px;height:80px;
  border-radius:50%;
  margin:0 auto 20px;
  display:flex;align-items:center;justify-content:center;
  font-size:2rem;
}
.reward-icon.green{background:linear-gradient(135deg,#d1fae5,#a7f3d0);}
.reward-icon.gold{background:linear-gradient(135deg,#fef3c7,#fde68a);}
.reward-icon.platinum{background:linear-gradient(135deg,#e0f2fe,#bae6fd);}
.reward-amount{
  font-family:'Playfair Display',serif;
  font-size:2.3rem;
  font-weight:800;
  color:var(--green-dark);
  line-height:1.1;
}
.reward-amount span{font-size:1.1rem;font-weight:700;color:var(--green-mid);}
.reward-type{
  font-size:0.92rem;
  font-weight:700;
  color:var(--text-mid);
  margin:6px 0 16px;
  text-transform:uppercase;
  letter-spacing:0.08em;
}
.reward-features{list-style:none;text-align:left;margin-bottom:24px;}
.reward-features li{
  font-size:0.88rem;color:#3d6b50;
  padding:5px 0;
  display:flex;align-items:center;gap:8px;
}
.reward-features li::before{content:'✓';color:var(--green-bright);font-weight:900;}
.btn-card{
  display:block;width:100%;
  padding:13px;
  border-radius:40px;
  border:none;
  font-weight:800;
  font-size:0.95rem;
  cursor:pointer;
  transition:var(--transition);
}
.btn-card.green{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;box-shadow:0 4px 18px rgba(34,197,94,0.3);}
.btn-card.gold{background:linear-gradient(135deg,var(--gold-dark),var(--gold));color:var(--green-dark);box-shadow:0 4px 18px rgba(212,160,23,0.35);}
.btn-card:hover{transform:translateY(-2px);filter:brightness(1.07);}

/* ===========================
   HOW IT WORKS
=========================== */
#how{
  background:linear-gradient(160deg,var(--off-white),#e8f5ec);
  padding:80px 0;
}
.steps-wrap{
  display:flex;
  align-items:flex-start;
  justify-content:center;
  gap:0;
  position:relative;
}
.step-card{
  flex:1;
  max-width:280px;
  text-align:center;
  padding:36px 24px;
  background:var(--white);
  border-radius:var(--radius-lg);
  box-shadow:var(--shadow-card);
  border:1.5px solid rgba(34,197,94,0.1);
  position:relative;
  transition:var(--transition);
}
.step-card:hover{transform:translateY(-6px);box-shadow:0 18px 44px rgba(10,74,46,0.15);}
.step-num{
  width:44px;height:44px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--green-mid),var(--green-light));
  color:#fff;
  font-size:1.1rem;
  font-weight:900;
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 18px;
  box-shadow:0 4px 14px rgba(15,107,66,0.35);
}
.step-icon{
  font-size:2.4rem;
  margin-bottom:14px;
}
.step-title{
  font-size:1.05rem;
  font-weight:800;
  color:var(--green-dark);
  margin-bottom:8px;
}
.step-desc{font-size:0.88rem;color:var(--text-mid);}
.step-arrow{
  display:flex;align-items:center;justify-content:center;
  padding:0 8px;
  margin-top:50px;
  color:var(--gold-dark);
  font-size:1.6rem;
  flex-shrink:0;
}

/* ===========================
   TRUST BAR
=========================== */
#trust{
  background:linear-gradient(100deg,var(--green-dark) 0%,#0d5535 50%,var(--green-dark) 100%);
  padding:36px 0;
  border-top:2px solid rgba(245,200,66,0.3);
  border-bottom:2px solid rgba(245,200,66,0.3);
}
.trust-inner{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:40px;
  flex-wrap:wrap;
}
.trust-item{
  display:flex;align-items:center;gap:12px;
  font-weight:700;
  font-size:0.9rem;
  color:rgba(255,255,255,0.92);
  white-space:nowrap;
}
.trust-icon{
  width:38px;height:38px;
  border-radius:50%;
  background:rgba(245,200,66,0.15);
  border:1.5px solid rgba(245,200,66,0.35);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.trust-divider{
  width:1px;height:36px;
  background:rgba(255,255,255,0.14);
}

/* ===========================
   LIVE PARTICIPATION
=========================== */
#live{background:var(--white);padding:48px 0 56px;}
.live-grid{
  display:flex;
  flex-direction:column;
  gap:24px;
}
.live-top-row{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:24px;
  align-items:stretch;
}
.live-bottom-row{
  display:flex;
  justify-content:center;
}
.live-bottom-row .live-card{
  width:100%;
  max-width:520px;
}
.live-card{
  background:var(--white);
  border-radius:var(--radius-lg);
  box-shadow:var(--shadow-card);
  border:1.5px solid rgba(34,197,94,0.12);
  padding:28px 22px;
  display:flex;flex-direction:column;
}
.live-card-title{
  font-size:0.82rem;
  font-weight:800;
  color:var(--green-light);
  text-transform:uppercase;
  letter-spacing:0.1em;
  margin-bottom:18px;
  display:flex;align-items:center;gap:8px;
}
.live-dot{
  width:8px;height:8px;border-radius:50%;
  background:var(--green-bright);
  animation:live-pulse 1.4s infinite;
  flex-shrink:0;
}
@keyframes live-pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.55;transform:scale(1.4);}}
/* Feed */
.feed-list{display:flex;flex-direction:column;gap:10px;flex:1;}
.feed-item{
  display:flex;align-items:center;gap:12px;
  padding:10px 12px;
  border-radius:12px;
  background:var(--gray-soft);
  animation:feed-slide 0.5s ease;
}
@keyframes feed-slide{from{opacity:0;transform:translateX(-10px);}to{opacity:1;transform:translateX(0);}}
.feed-avatar{
  width:38px;height:38px;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;
  font-weight:800;
  color:#fff;
  flex-shrink:0;
  background:linear-gradient(135deg,var(--green-mid),var(--green-light));
}
.feed-info{flex:1;}
.feed-name{font-size:0.88rem;font-weight:800;color:var(--green-dark);}
.feed-city{font-size:0.78rem;color:var(--text-mid);}
.feed-time{
  font-size:0.72rem;
  font-weight:700;
  background:linear-gradient(135deg,#d1fae5,#a7f3d0);
  color:#065f46;
  padding:3px 10px;
  border-radius:20px;
  white-space:nowrap;
}
/* Counter card */
.counter-center{text-align:center;flex:1;display:flex;flex-direction:column;justify-content:center;}
.live-number{
  font-family:'Playfair Display',serif;
  font-size:2.6rem;
  font-weight:800;
  color:var(--green-dark);
  line-height:1;
  margin-bottom:6px;
}
.live-number span{color:var(--gold-dark);}
.live-desc{font-size:0.88rem;color:var(--text-mid);margin-bottom:28px;font-weight:600;}
.progress-wrap{margin-bottom:10px;}
.progress-label{
  display:flex;justify-content:space-between;
  font-size:0.8rem;font-weight:700;
  color:var(--text-mid);
  margin-bottom:8px;
}
.progress-bar-bg{
  height:14px;
  background:#e5e7eb;
  border-radius:20px;
  overflow:hidden;
  margin-bottom:6px;
}
.progress-bar-fill{
  height:100%;
  background:linear-gradient(90deg,var(--green-bright),var(--green-light));
  border-radius:20px;
  width:0%;
  transition:width 2s cubic-bezier(.4,0,.2,1);
  position:relative;
}
.progress-bar-fill::after{
  content:'';
  position:absolute;top:0;right:0;bottom:0;width:30px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4));
  animation:shimmer 2s infinite;
}
@keyframes shimmer{0%{opacity:0;}50%{opacity:1;}100%{opacity:0;}}
.slots-text{font-size:0.82rem;color:#dc2626;font-weight:700;text-align:center;}
.urgency-row{
  margin-top:auto;
  padding:12px 14px;
  background:linear-gradient(135deg,#fff7ed,#ffedd5);
  border:1.5px solid #fed7aa;
  border-radius:12px;
  font-size:0.82rem;
  font-weight:700;
  color:#9a3412;
  text-align:center;
}
/* Form card */
.form-card input,
.form-card select{
  width:100%;
  padding:14px 16px;
  border:1.5px solid rgba(34,197,94,0.25);
  border-radius:12px;
  font-size:0.95rem;
  font-weight:600;
  color:var(--text-dark);
  background:var(--off-white);
  margin-bottom:14px;
  outline:none;
  transition:var(--transition);
}
.form-card input:focus,
.form-card select:focus{
  border-color:var(--green-bright);
  background:#fff;
  box-shadow:0 0 0 4px rgba(34,197,94,0.1);
}
.form-card input.error{border-color:#ef4444;box-shadow:0 0 0 4px rgba(239,68,68,0.1);}
.error-msg{color:#dc2626;font-size:0.78rem;font-weight:700;margin:-8px 0 10px 4px;display:none;}
.btn-form{
  width:100%;
  padding:15px;
  background:linear-gradient(135deg,#22c55e,#16a34a);
  color:#fff;
  border:none;
  border-radius:40px;
  font-size:1rem;
  font-weight:800;
  cursor:pointer;
  box-shadow:0 4px 20px rgba(34,197,94,0.35);
  transition:var(--transition);
  margin-bottom:12px;
  letter-spacing:0.01em;
}
.btn-form:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(34,197,94,0.5);}
.form-privacy{
  font-size:0.75rem;
  color:#6b7280;
  text-align:left;
  display:flex;align-items:flex-start;gap:6px;
}
.form-privacy svg{flex-shrink:0;margin-top:2px;}
.form-card{text-align:left !important;}
.form-card *{text-align:left;}
.form-card .live-card-title{text-align:left;}
.btn-form{text-align:center !important;}
.input-label{
  font-size:0.8rem;font-weight:700;
  color:var(--text-mid);
  margin-bottom:5px;
  display:block;
}

/* ===========================
   TESTIMONIALS
=========================== */
#testimonials{
  background:linear-gradient(160deg,var(--off-white),#e8f5ec);
  padding:80px 0;
}
.testi-card{
  background:var(--white);
  border-radius:var(--radius-lg);
  box-shadow:var(--shadow-card);
  border:1.5px solid rgba(34,197,94,0.1);
  padding:28px 24px;
  display:flex;
  flex-direction:column;
  gap:14px;
  transition:var(--transition);
}
.testi-card:hover{transform:translateY(-6px);box-shadow:0 18px 44px rgba(10,74,46,0.15);}
.testi-top{display:flex;align-items:center;gap:14px;}
.testi-avatar{
  width:50px;height:50px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--green-mid),var(--green-light));
  display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;
  font-weight:800;
  color:#fff;
  flex-shrink:0;
}
.testi-name{font-weight:800;font-size:0.97rem;color:var(--green-dark);}
.testi-city{font-size:0.8rem;color:var(--text-mid);}
.stars{color:var(--gold-dark);font-size:1rem;letter-spacing:2px;}
.testi-text{
  font-size:0.93rem;
  color:#374151;
  line-height:1.65;
  font-style:italic;
}
.testi-tag{
  display:inline-flex;align-items:center;gap:6px;
  background:#d1fae5;
  color:#065f46;
  font-size:0.75rem;
  font-weight:700;
  padding:4px 12px;
  border-radius:20px;
  width:fit-content;
}

/* ===========================
   FOOTER
=========================== */
#footer{
  background:linear-gradient(160deg,#052616 0%,#073d22 100%);
  padding:52px 0 30px;
  border-top:3px solid rgba(245,200,66,0.3);
}
.footer-brand{
  text-align:center;
  margin-bottom:28px;
}
.footer-logo{
