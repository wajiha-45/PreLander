<script>
/* ---- COUNTDOWN TIMER ---- */
(function(){
  // Set expiry 8h24m19s from now
  const expiry = Date.now() + (8*3600 + 24*60 + 19) * 1000;
  function pad(n){return String(n).padStart(2,'0');}
  function tick(){
    const diff = Math.max(0, expiry - Date.now());
    const h = Math.floor(diff/3600000);
    const m = Math.floor((diff%3600000)/60000);
    const s = Math.floor((diff%60000)/1000);
    document.getElementById('t-h').textContent = pad(h);
    document.getElementById('t-m').textContent = pad(m);
    document.getElementById('t-s').textContent = pad(s);
    if(diff > 0) setTimeout(tick, 1000);
  }
  tick();
})();

/* ---- CONFETTI / GOLD PARTICLES ---- */
(function(){
  const canvas = document.getElementById('confetti-canvas');
  const ctx = canvas.getContext('2d');
  let W,H,particles=[];
  const COLORS=['#f5c842','#fde68a','#22c55e','#ffffff','#d4a017','#a7f3d0'];
  function resize(){
    W=canvas.width=canvas.offsetWidth;
    H=canvas.height=canvas.offsetHeight;
  }
  function Particle(){
    this.x=Math.random()*W;
    this.y=Math.random()*H+H;
    this.size=Math.random()*4+2;
    this.speedY=-(Math.random()*0.7+0.3);
    this.speedX=(Math.random()-0.5)*0.5;
    this.opacity=Math.random()*0.5+0.2;
    this.color=COLORS[Math.floor(Math.random()*COLORS.length)];
    this.shape=Math.random()>0.5?'circle':'rect';
    this.angle=Math.random()*360;
    this.spin=(Math.random()-0.5)*1.5;
  }
  function init(){
    resize();
    particles=[];
    for(let i=0;i<55;i++){
      const p=new Particle();
      p.y=Math.random()*H; // start spread out
      particles.push(p);
    }
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    particles.forEach(p=>{
      ctx.save();
      ctx.globalAlpha=p.opacity;
      ctx.fillStyle=p.color;
      ctx.translate(p.x,p.y);
      ctx.rotate(p.angle*Math.PI/180);
      if(p.shape==='circle'){
        ctx.beginPath();ctx.arc(0,0,p.size,0,Math.PI*2);ctx.fill();
      } else {
        ctx.fillRect(-p.size,-p.size/2,p.size*2,p.size);
      }
      ctx.restore();
      p.y+=p.speedY;p.x+=p.speedX;p.angle+=p.spin;
      if(p.y<-10){p.y=H+10;p.x=Math.random()*W;}
    });
    requestAnimationFrame(draw);
  }
  window.addEventListener('resize',init);
  init();draw();
})();

/* ---- SCROLL FADE-IN ---- */
(function(){
  const els=document.querySelectorAll('.fade-up');
  const io=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target);}
    });
  },{threshold:0.12});
  els.forEach(el=>io.observe(el));
})();

/* ---- PROGRESS BAR ANIMATION ---- */
(function(){
  const fill=document.getElementById('progress-fill');
  const io=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        setTimeout(()=>{fill.style.width='89%';},200);
        io.unobserve(e.target);
      }
    });
  },{threshold:0.3});
  io.observe(fill);
})();

/* ---- LIVE COUNTER ANIMATION ---- */
(function(){
  let count=12458;
  const el=document.getElementById('live-count');
  const slotsEl=document.getElementById('slots-left');
  const pctEl=document.getElementById('slots-pct');
  function fmt(n){return n.toString().replace(/\B(?=(\d{3})+(?!\d))/,',');}
  setInterval(()=>{
    const inc=Math.floor(Math.random()*3)+1;
    count+=inc;
    const slots=Math.max(0,14000-count);
    const pct=Math.min(100,Math.round((count/14000)*100));
    el.textContent=fmt(count);
    slotsEl.textContent=fmt(slots);
    pctEl.textContent=pct+'%';
    document.getElementById('progress-fill').style.width=pct+'%';
  },2800);
})();

